# ---------------------------------------------------------------------------
# .NET / ASP.NET Core .gitignore for DMS API
# ---------------------------------------------------------------------------

# Build results
[Bb]in/
[Oo]bj/
[Oo]ut/
[Dd]ebug/
[Rr]elease/
x64/
x86/
build/
bld/
[Ll]og/
[Ll]ogs/

# Visual Studio / Rider / VS Code
.vs/
.vscode/
.idea/
*.user
*.userosscache
*.suo
*.userprefs
*_i.c
*_p.c
*.rsp
*.svclog
*.scc

# Runtime / app logs (Serilog writes here)
logs/
*.log

# ---------------------------------------------------------------------------
# Secrets — DO NOT commit real connection strings / JWT keys / passwords.
# Keep these out; use user-secrets or environment variables instead.
# ---------------------------------------------------------------------------
appsettings.*.local.json
secrets.json
*.pfx
*.p12

# .NET user secrets store is outside the repo by default, but ignore any local copy
**/UserSecrets/

# Test results / coverage
[Tt]est[Rr]esult*/
coverage*.json
coverage*.xml
*.coverage
*.trx

# NuGet
*.nupkg
*.snupkg
.nuget/
packages/
!packages/build/

# EF Core / SQLite local files (if any)
*.db
*.db-shm
*.db-wal

# OS files
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
.DS_Store

# Publish output
publish/
*.pubxml.user
