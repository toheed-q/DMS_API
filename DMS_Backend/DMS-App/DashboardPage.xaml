<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DMS_App.DashboardPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource DmsBg}, Dark={StaticResource DmsBgDark}}">

    <!-- Placeholder. Signing in lands here; the real salesman dashboard is next. -->
    <VerticalStackLayout VerticalOptions="Center" Spacing="8" Padding="24">
        <Label x:Name="WelcomeLabel"
               Text="Signed in"
               FontSize="28" FontAttributes="Bold"
               HorizontalTextAlignment="Center"
               TextColor="{AppThemeBinding Light={StaticResource DmsText}, Dark={StaticResource DmsTextDark}}" />
        <Label Text="Your dashboard goes here."
               FontSize="15"
               HorizontalTextAlignment="Center"
               TextColor="{AppThemeBinding Light={StaticResource DmsTextSecondary}, Dark={StaticResource DmsTextSecondaryDark}}" />
    </VerticalStackLayout>
</ContentPage>
