<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="DMS_App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:DMS_App"
    xmlns:onboarding="clr-namespace:DMS_App.Onboarding"
    Shell.FlyoutBehavior="Disabled"
    Shell.NavBarIsVisible="False"
    Title="DMS Field">

    <!-- Exactly ONE root ShellContent. A second one here would make Shell treat the
         two as tabs and inflate a Material BottomNavigationView — chrome this flow
         doesn't want, and which crashes on strict Material themes. Other pages
         (login, and later the app) are registered as routes and navigated to. -->
    <ShellContent
        ContentTemplate="{DataTemplate onboarding:OnboardingPage}"
        Route="onboarding" />

</Shell>
