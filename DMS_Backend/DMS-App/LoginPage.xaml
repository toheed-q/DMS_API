<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:DMS_App.Onboarding.Controls"
             xmlns:draw="clr-namespace:DMS_App.Auth.Drawables"
             x:Class="DMS_App.LoginPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource DmsBg}, Dark={StaticResource DmsBgDark}}">

    <ContentPage.Resources>
        <draw:LogoDrawable x:Key="Logo" />

        <!-- Field chrome, defined once (DRY). -->
        <Style x:Key="FieldLabel" TargetType="Label">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="Margin" Value="4,0,0,6" />
            <Setter Property="TextColor"
                    Value="{AppThemeBinding Light={StaticResource DmsTextSecondary}, Dark={StaticResource DmsTextSecondaryDark}}" />
        </Style>

        <!-- Filled field: soft background, no visible border at rest; the border turns
             primary on focus (wired in code-behind). No native underline (see the
             EntryHandler mapping in MauiProgram). -->
        <Style x:Key="FieldBorder" TargetType="Border">
            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#EFF3F8, Dark=#2A363D}" />
            <Setter Property="Stroke" Value="Transparent" />
            <Setter Property="StrokeThickness" Value="1.5" />
            <Setter Property="HeightRequest" Value="56" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="StrokeShape">
                <RoundRectangle CornerRadius="14" />
            </Setter>
        </Style>

        <Style x:Key="FieldError" TargetType="Label">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="4,6,0,0" />
            <Setter Property="TextColor" Value="{StaticResource DmsDanger}" />
        </Style>
    </ContentPage.Resources>

    <ScrollView>
        <!-- MaximumWidthRequest keeps the form readable on tablets; on a phone it just
             fills the 24dp-inset column. -->
        <Grid Padding="24,0" RowDefinitions="*,Auto,*">

            <VerticalStackLayout Grid.Row="1"
                                 Spacing="0"
                                 HorizontalOptions="Center"
                                 MaximumWidthRequest="460"
                                 Padding="0,40">

                <!-- Brand -->
                <Border WidthRequest="76" HeightRequest="76"
                        HorizontalOptions="Center"
                        BackgroundColor="{AppThemeBinding Light={StaticResource DmsSurface}, Dark={StaticResource DmsSurfaceDark}}"
                        StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="{StaticResource DmsPrimary}" Radius="18" Opacity="0.22" Offset="0,8" />
                    </Border.Shadow>
                    <GraphicsView Drawable="{StaticResource Logo}" Margin="14" />
                </Border>

                <Label Text="DMS Field"
                       FontSize="26" FontAttributes="Bold"
                       HorizontalOptions="Center"
                       Margin="0,16,0,0"
                       TextColor="{AppThemeBinding Light={StaticResource DmsText}, Dark={StaticResource DmsTextDark}}" />
                <Label Text="DISTRIBUTOR MOBILITY SYSTEM"
                       FontSize="10" CharacterSpacing="2"
                       HorizontalOptions="Center"
                       Margin="0,4,0,0"
                       TextColor="{AppThemeBinding Light={StaticResource DmsTextSecondary}, Dark={StaticResource DmsTextSecondaryDark}}" />

                <!-- Heading -->
                <Label Text="Welcome back"
                       FontSize="24" FontAttributes="Bold"
                       HorizontalOptions="Center"
                       Margin="0,36,0,0"
                       TextColor="{AppThemeBinding Light={StaticResource DmsText}, Dark={StaticResource DmsTextDark}}" />
                <Label Text="Sign in to continue to your account"
                       FontSize="14"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"
                       Margin="0,6,0,0"
                       TextColor="{AppThemeBinding Light={StaticResource DmsTextSecondary}, Dark={StaticResource DmsTextSecondaryDark}}" />

                <!-- Error banner -->
                <Border IsVisible="{Binding HasError}"
                        BackgroundColor="#1AF44336"
                        Stroke="#66F44336" StrokeThickness="1"
                        Padding="14,10" Margin="0,24,0,0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <Label Text="!" FontAttributes="Bold" FontSize="15"
                               WidthRequest="20" HeightRequest="20"
                               BackgroundColor="{StaticResource DmsDanger}" TextColor="White"
                               HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        <Label Grid.Column="1"
                               Text="{Binding ErrorMessage}"
                               FontSize="13" VerticalOptions="Center"
                               TextColor="{StaticResource DmsDanger}" />
                    </Grid>
                </Border>

                <!-- Username -->
                <Label Text="Username" Style="{StaticResource FieldLabel}" Margin="4,28,0,6" />
                <Border x:Name="UsernameBorder" Style="{StaticResource FieldBorder}">
                    <Entry x:Name="UsernameEntry"
                           Text="{Binding Username}"
                           Placeholder="e.g. imran"
                           ReturnType="Next"
                           Keyboard="Text"
                           IsSpellCheckEnabled="False"
                           BackgroundColor="Transparent"
                           FontSize="16"
                           TextColor="{AppThemeBinding Light={StaticResource DmsText}, Dark={StaticResource DmsTextDark}}"
                           PlaceholderColor="{StaticResource Gray400}"
                           VerticalOptions="Center" />
                </Border>
                <Label Text="{Binding UsernameError}" IsVisible="{Binding HasUsernameError}"
                       Style="{StaticResource FieldError}" />

                <!-- Password -->
                <Label Text="Password" Style="{StaticResource FieldLabel}" Margin="4,18,0,6" />
                <Border x:Name="PasswordBorder" Style="{StaticResource FieldBorder}">
                    <Grid ColumnDefinitions="*,Auto">
                        <Entry x:Name="PasswordEntry"
                               Text="{Binding Password}"
                               Placeholder="Your password"
                               IsPassword="{Binding IsPasswordHidden}"
                               ReturnType="Go"
                               ReturnCommand="{Binding LoginCommand}"
                               BackgroundColor="Transparent"
                               FontSize="16"
                               TextColor="{AppThemeBinding Light={StaticResource DmsText}, Dark={StaticResource DmsTextDark}}"
                               PlaceholderColor="{StaticResource Gray400}"
                               VerticalOptions="Center" />
                        <Button Grid.Column="1"
                                Text="{Binding PasswordToggleText}"
                                Command="{Binding TogglePasswordCommand}"
                                BackgroundColor="Transparent"
                                Padding="10,0" Margin="4,0,-4,0"
                                FontSize="13" FontAttributes="Bold"
                                MinimumWidthRequest="52"
                                TextColor="{AppThemeBinding Light={StaticResource DmsLink}, Dark={StaticResource DmsLinkDark}}" />
                    </Grid>
                </Border>
                <Label Text="{Binding PasswordError}" IsVisible="{Binding HasPasswordError}"
                       Style="{StaticResource FieldError}" />

                <!-- Forgot password -->
                <Button Text="Forgot password?"
                        Clicked="OnForgotPassword"
                        HorizontalOptions="End"
                        BackgroundColor="Transparent"
                        Padding="8,4" Margin="0,10,0,0"
                        HeightRequest="40"
                        FontSize="13"
                        TextColor="{AppThemeBinding Light={StaticResource DmsLink}, Dark={StaticResource DmsLinkDark}}" />

                <!-- Sign in -->
                <Grid Margin="0,18,0,0">
                    <controls:PrimaryCta x:Name="SignInButton"
                                         Text="{Binding PrimaryButtonText}"
                                         Command="{Binding LoginCommand}"
                                         IsEnabled="{Binding IsNotBusy}" />
                    <ActivityIndicator IsVisible="{Binding IsBusy}"
                                       IsRunning="{Binding IsBusy}"
                                       Color="White"
                                       WidthRequest="22" HeightRequest="22"
                                       HorizontalOptions="End" VerticalOptions="Center"
                                       Margin="0,0,24,0"
                                       InputTransparent="True" />
                </Grid>

                <Label Text="Secure · Real-time · Built for the field"
                       FontSize="12"
                       HorizontalOptions="Center"
                       Margin="0,28,0,0"
                       TextColor="{AppThemeBinding Light={StaticResource DmsTrustLine}, Dark={StaticResource DmsTrustLineDark}}" />

            </VerticalStackLayout>
        </Grid>
    </ScrollView>
</ContentPage>
