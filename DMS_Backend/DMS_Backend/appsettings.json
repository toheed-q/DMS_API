{
  // Secrets (connection string, JWT key, seed admin password) are intentionally NOT
  // in this file. Supply them via user-secrets in development or environment
  // variables in production:
  //   dotnet user-secrets set "ConnectionStrings:DefaultConnection" "<value>"
  //   dotnet user-secrets set "Jwt:Key" "<64+ random chars>"
  //   env: ConnectionStrings__DefaultConnection / Jwt__Key / Seed__AdminPassword
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Jwt": {
    "Key": "",
    "Issuer": "DMS.Api",
    "Audience": "DMS.Clients",
    "ExpiryMinutes": 480
  },
  "RateLimiting": {
    "Auth": { "PermitLimit": 5, "WindowSeconds": 60 },
    "Global": { "PermitLimit": 100, "WindowSeconds": 60 }
  },
  "Seed": {
    "AdminUsername": "admin"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
