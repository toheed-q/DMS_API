// Template for production hosting (MonsterASP.net).
//
// Copy this file to "appsettings.Production.json" (which is git-ignored), fill in
// the real values, and publish it with the app. The API validates these at startup
// and refuses to boot if they are missing or too weak.
//
//   ConnectionStrings:DefaultConnection  the MSSQL connection string from the host's
//                                        database "Manage" page (SQL auth, not
//                                        Integrated Security)
//   Jwt:Key                              64+ random characters. Must be at least 32.
//                                        Generate one, don't reuse the dev key.
//   Seed:AdminPassword                   the first admin's password. Set this BEFORE
//                                        the first deploy — otherwise a random one is
//                                        generated and only written to the log file.
//
// Alternatively supply the same values as environment variables, which override this
// file:  ConnectionStrings__DefaultConnection / Jwt__Key / Seed__AdminPassword
{
  "ConnectionStrings": {
    "DefaultConnection": "Server=db60283.databaseasp.net;Database=db60283;User Id=<DB_USER>;Password=<DB_PASSWORD>;Encrypt=True;TrustServerCertificate=True;MultipleActiveResultSets=True;"
  },
  "Jwt": {
    "Key": "<64+ RANDOM CHARACTERS>",
    "Issuer": "DMS.Api",
    "Audience": "DMS.Clients",
    "ExpiryMinutes": 480
  },
  "Seed": {
    "AdminUsername": "admin",
    "AdminPassword": "<CHOOSE A STRONG ADMIN PASSWORD>"
  }
}
